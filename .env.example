# OpenEMIS API Configuration

# Base URL for the OpenEMIS core instance
OPENEMIS_BASE_URL=https://demo.openemis.org/core

# OpenEMIS login credentials (required at API call time; server boots without them)
OPENEMIS_USERNAME=admin
OPENEMIS_PASSWORD=your_password_here
OPENEMIS_API_KEY=your_api_key_here

# Request timeout in milliseconds (default 30000)
OPENEMIS_TIMEOUT_MS=30000

# Path to vault directory for caching data
OPENEMIS_VAULT_PATH=/Users/khindol/Documents/Vaults/Openemis/claude

# Path to manifest.jsonl describing available API endpoints
OPENEMIS_MANIFEST_PATH=/Users/khindol/webstore/utils/mcp-openemis-gen/manifest.jsonl

# Path to grouped-manifest.json with pre-computed hierarchical index (optional, defaults to data/grouped-manifest.json)
OPENEMIS_GROUPED_PATH=data/grouped-manifest.json
